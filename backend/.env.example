# =============================================================================
# HERB-TRACECHAIN BACKEND — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Server
PORT=5000

# MongoDB Atlas
# Get your connection string from: https://cloud.mongodb.com
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/herb-tracechain?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=24h

# Hyperledger Fabric (set to 'true' when running on Codespaces with Fabric network)
FABRIC_ENABLED=false
FABRIC_CHANNEL=mychannel
FABRIC_CHAINCODE=herbcc
FABRIC_WALLET_PATH=./wallet
FABRIC_CONNECTION_PROFILE=./connection-org1.json
FABRIC_CA_URL=https://localhost:7054

# Ethereum / Hardhat (set to 'true' when Hardhat node is running)
ETHEREUM_ENABLED=false
ETHEREUM_RPC_URL=http://localhost:8545
ETHEREUM_CONTRACT_ADDRESS=
ETHEREUM_PRIVATE_KEY=
