PORT=3002
BACKEND_URL=http://localhost:5000
USE_MOCK_SMS=true

# Backend authentication — the gateway logs in as a collector user
# to get a JWT token automatically. Set these to a valid collector account.
BACKEND_COLLECTOR_EMAIL=collector@example.com
BACKEND_COLLECTOR_PASSWORD=password

# Only needed if USE_MOCK_SMS=false (real Twilio):
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
